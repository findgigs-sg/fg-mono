# ──────────────────────────────────────────────
# @findgigs/db — Database
# Default: local Postgres via docker compose (./scripts/setup-db.sh)
# For Supabase: replace with your project's pooler/direct URLs
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/findgigs"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/findgigs"

# ──────────────────────────────────────────────
# @findgigs/auth — Better Auth
# Generate with: openssl rand -base64 32
# ──────────────────────────────────────────────
AUTH_SECRET=""
AUTH_REDIRECT_PROXY_URL=""

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In (Apple Developer Console → Certificates, Identifiers & Profiles)
APPLE_CLIENT_ID=""         # Services ID (e.g., com.findgigs.auth)
APPLE_CLIENT_SECRET=""     # JWT generated from .p8 key (must be regenerated every 6 months)
APPLE_APP_BUNDLE_ID=""     # iOS app bundle identifier (for native sign-in)
